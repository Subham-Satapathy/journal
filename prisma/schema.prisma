generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  symbol       String
  side         String   // "LONG" | "SHORT" | "BUY" | "SELL"
  entryPrice   Float
  exitPrice    Float?
  quantity     Float
  pnl          Float?
  pnlPercent   Float?
  fees         Float    @default(0)
  date         DateTime
  closeDate    DateTime?
  exchange     String?
  notes        String?
  tags         String?
  importSource String?  // "csv" | "excel" | "screenshot" | "manual"
  orderId      String?  // Platform order/trade ID (UUID from broker) — used for deduplication
  currency     String   @default("USDT")  // "USDT" | "INR"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Deduplicate by broker order ID when present
  @@unique([orderId])
  @@index([userId, date])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trades       Trade[]
  dailyPnls    DailyPnl[]
  emailOtps    EmailVerificationOtp[]
}

model DailyPnl {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       String   // IST day key: yyyy-MM-dd
  pnl        Float
  tradeCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model EmailVerificationOtp {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model BillingCustomer {
  id            String           @id @default(cuid())
  email         String           @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subscriptions Subscription[]
  invoices      CryptoInvoice[]
}

model Subscription {
  id                 String          @id @default(cuid())
  customerId         String
  customer           BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  planId             String
  billingCycle       String
  status             String          @default("inactive")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  activatedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([customerId, status])
}

model CryptoInvoice {
  id                String          @id @default(cuid())
  customerId        String
  customer          BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider          String
  providerInvoiceId String?
  orderId           String          @unique
  planId            String
  billingCycle      String
  status            String          @default("created")
  amountUsd         Float
  checkoutUrl       String?
  payCurrency       String?
  paymentId         String?
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([customerId, status])
}
